# ============ Required ============

# Discord Developer Portal → your app → Bot → Reset Token
DISCORD_TOKEN=

# fish.audio dashboard (cloned-voice TTS)
FISH_AUDIO_API_KEY=

# console.anthropic.com (conversation LLM)
ANTHROPIC_API_KEY=

# ============ Optional ============

# console.groq.com — fast multi-party addressee arbiter (~350ms);
# without it arbitration falls back to the conversation LLM
GROQ_API_KEY=

# Fish voice model id used by live tests / demo scripts
TEST_VOICE_ID=

# your dev server id — slash commands sync instantly instead of ~1h
TEST_GUILD_ID=
